				Escribir ""
				Escribir "  Algoritmo  | Big-O  | Operacion Dominante"
				Escribir "  -----------|--------|-----------------------------"
				Escribir "  FIFO       | O(1)   | Extraccion en Cola Circular"
				Escribir "  LRU        | O(1)   | Reubicacion en Lista Enlazada"
				Escribir "  Reloj      | O(n)   | Recorrido Circular de Marcos"
				Escribir "  Optimo     | O(n*m) | Busqueda Prospectiva Futura"
				Escribir ""
				Escribir "  Donde:"
				Escribir "  n = Numero de marcos de memoria fisica"
				Escribir "  m = Numero de referencias futuras a analizar"
				Escribir ""
				Escribir "  Conclusion:"
				Escribir "  FIFO y LRU son O(1): seleccion inmediata de victima."
				Escribir "  Reloj es O(n): recorre marcos hasta encontrar R=0."
				Escribir "  Optimo es O(n*m): inviable en tiempo real."
